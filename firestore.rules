rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------
    // admin/config  ->  { uids: ["<uid1>", "<uid2>"] }  (max 2 admins)
    //
    // - Anyone can READ this doc, since it only exposes UIDs, not a
    //   secret. The client needs to read it to compare its own UID.
    // - CREATE is allowed only to start the list with exactly ONE
    //   uid, and only if that uid matches the caller's own auth.uid.
    // - UPDATE is allowed exactly once more, ONLY to append a SECOND,
    //   different uid (the caller's own) onto an existing 1-item list.
    //   The first uid can never be changed or removed this way.
    // - Once the list has 2 uids, all further update/delete is
    //   permanently disabled — the two admin slots are locked in.
    // ------------------------------------------------------------
    match /admin/config {
      allow read: if true;

      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['uids', 'claimedAt'])
                    && request.resource.data.uids.size() == 1
                    && request.resource.data.uids[0] == request.auth.uid;

      allow update: if request.auth != null
                    && resource.data.uids.size() == 1
                    && request.resource.data.keys().hasOnly(['uids', 'claimedAt'])
                    && request.resource.data.uids.size() == 2
                    && request.resource.data.uids[0] == resource.data.uids[0]
                    && request.resource.data.uids[1] == request.auth.uid
                    && request.auth.uid != resource.data.uids[0];

      allow delete: if false;
    }

    // ------------------------------------------------------------
    // Helper: is the caller one of the stored admin UIDs?
    // ------------------------------------------------------------
    function isAdmin() {
      return request.auth != null
             && exists(/databases/$(database)/documents/admin/config)
             && request.auth.uid in get(/databases/$(database)/documents/admin/config).data.uids;
    }

    // ------------------------------------------------------------
    // incidents/{incidentId}  -> أحداث الخريطة
    //
    // - Readable by everyone (public view-only data).
    // - Writable only by a UID listed in admin/config.uids.
    // ------------------------------------------------------------
    match /incidents/{incidentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ------------------------------------------------------------
    // entries/{entryId}  -> (kept for backward compatibility)
    // ------------------------------------------------------------
    match /entries/{entryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
